<%- include('../partials/header') %>
<div class="max-w-7xl mx-auto p-8">
    <h1 class="text-4xl font-black italic uppercase mb-8">My <span class="text-red-600">Digital Wallet</span></h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% tickets.forEach(ticket => { %>
            <div class="bg-white border-2 border-black rounded-[2.5rem] overflow-hidden shadow-2xl transition hover:scale-105">
                <div class="bg-black text-white p-6 text-center">
                    <h3 class="text-xl font-bold uppercase tracking-widest text-red-500"><%= ticket.event.singerName %></h3>
                    <p class="text-[10px] opacity-70"><%= ticket.event.eventTitle %></p>
                </div>
                
                <div class="p-8 text-center">
                    <img src="<%= ticket.qrImage %>" class="w-48 h-48 mx-auto mb-4 border-4 border-gray-100 p-2 rounded-xl">
                    <div class="bg-gray-100 rounded-2xl py-3 mb-4">
                        <p class="text-xs font-bold text-gray-500 uppercase">Seat Number</p>
                        <p class="text-2xl font-black text-black">#<%= ticket.seatNo %></p>
                    </div>
                    
                    <div class="flex items-center justify-center space-x-2">
                        <div class="w-3 h-3 rounded-full <%= ticket.isUsed ? 'bg-red-500' : 'bg-green-500' %>"></div>
                        <span class="text-xs font-black uppercase tracking-tighter">
                            <%= ticket.isUsed ? 'Used / Scanned' : 'Valid Entry Pass' %>
                        </span>
                    </div>
                </div>
                
                <div class="bg-gray-50 p-4 border-t border-dashed border-gray-300 text-center">
                    <p class="text-[10px] font-mono text-gray-400">PASS ID: <%= ticket.ticketID %></p>
                </div>
            </div>
        <% }) %>
    </div>
</div>