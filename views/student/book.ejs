<%- include('../partials/header') %>
<div class="max-w-4xl mx-auto p-8">
    <div class="bg-white rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row border border-gray-100">
        <div class="md:w-1/2 bg-black p-10 text-white flex flex-col justify-center relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10 text-9xl font-black italic">PASS</div>
            <h4 class="text-red-600 font-bold uppercase tracking-widest text-xs mb-2">Live Concert</h4>
            <h1 class="text-4xl font-black uppercase italic mb-4"><%= event.singerName %></h1>
            <p class="text-gray-400 text-sm mb-8"><%= event.eventTitle %></p>
            <div class="space-y-4 text-sm font-bold">
                <p><i class="fa fa-calendar-alt mr-3 text-red-600"></i> <%= event.date %></p>
                <p><i class="fa fa-map-marker-alt mr-3 text-red-600"></i> <%= event.venue %></p>
            </div>
        </div>
        
        <div class="md:w-1/2 p-10">
            <h2 class="text-2xl font-black uppercase mb-8 italic">Choose <span class="text-red-600">Your Zone</span></h2>
            <form action="/confirm-booking" method="POST" class="space-y-6">
                <input type="hidden" name="eventId" value="<%= event._id %>">
                
                <div class="space-y-4">
                    <label class="flex items-center p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:border-red-500 transition group has-[:checked]:border-black has-[:checked]:bg-gray-50">
                        <input type="radio" name="ticketType" value="Normal" checked class="w-5 h-5 accent-red-600">
                        <div class="ml-4">
                            <span class="block font-black uppercase tracking-tighter">Normal Seat</span>
                            <span class="text-xs text-gray-400">Standard entry - ₹<%= event.price %></span>
                        </div>
                    </label>

                    <label class="flex items-center p-4 border-2 border-gray-100 rounded-2xl cursor-pointer hover:border-red-500 transition group has-[:checked]:border-black has-[:checked]:bg-gray-50">
                        <input type="radio" name="ticketType" value="Premium" class="w-5 h-5 accent-red-600">
                        <div class="ml-4">
                            <span class="block font-black uppercase tracking-tighter text-red-600">Premium Zone ✨</span>
                            <span class="text-xs text-gray-400">Front Row Access - ₹<%= event.price + 500 %></span>
                        </div>
                    </label>
                </div>

                <button type="submit" class="w-full bg-black text-white font-black py-4 rounded-2xl hover:bg-red-600 transition uppercase tracking-widest shadow-xl shadow-gray-200 active:scale-95">
                    Generate My Pass
                </button>
            </form>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>