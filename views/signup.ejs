<%- include('partials/header') %>
<div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="max-w-md w-full bg-white rounded-[3rem] shadow-2xl p-10 border border-gray-100">
        <div class="text-center mb-10">
            <h2 class="text-3xl font-black italic uppercase italic">Create <span class="text-red-600">Account</span></h2>
            <p class="text-gray-400 text-sm mt-2">Join the revolution of digital event access.</p>
        </div>
        
        <form action="/signup" method="POST" class="space-y-6">
            <div>
                <label class="text-[10px] font-black uppercase text-gray-400 ml-4 mb-1 block">Full Name</label>
                <input type="text" name="name" required class="w-full bg-gray-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-red-600 outline-none transition">
            </div>
            <div>
                <label class="text-[10px] font-black uppercase text-gray-400 ml-4 mb-1 block">Email Address</label>
                <input type="email" name="email" required class="w-full bg-gray-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-red-600 outline-none transition">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="text-[10px] font-black uppercase text-gray-400 ml-4 mb-1 block">Password</label>
                    <input type="password" name="password" required class="w-full bg-gray-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-red-600 outline-none transition">
                </div>
                <div>
                    <label class="text-[10px] font-black uppercase text-gray-400 ml-4 mb-1 block">Role</label>
                    <select name="role" class="w-full bg-gray-50 border-none rounded-2xl py-4 px-6 focus:ring-2 focus:ring-red-600 outline-none transition font-bold text-sm">
                        <option value="student">Student</option>
                        <option value="volunteer">Volunteer</option>
                    </select>
                </div>
            </div>
            
            <button type="submit" class="w-full bg-black text-white font-black uppercase py-4 rounded-2xl hover:bg-red-600 transition shadow-lg shadow-red-200 active:scale-95">
                Register Now
            </button>
        </form>
        
        <p class="text-center mt-8 text-sm text-gray-400">Already have an account? <a href="/login" class="text-red-600 font-bold">Sign In</a></p>
    </div>
</div>