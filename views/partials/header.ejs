<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FestPulse Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gray-50">
    <nav class="bg-black text-white p-4 sticky top-0 z-50 shadow-xl">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black italic tracking-tighter">FEST<span class="text-red-600">PULSE</span> PRO</a>
            <div class="flex items-center space-x-6 text-sm font-bold uppercase tracking-wider">
                <% if (user) { %>
                    <span class="text-gray-400">Hi, <span class="text-white"><%= user.name %></span></span>
                    <% if (user.role === 'student') { %>
                        <a href="/student/dashboard" class="hover:text-red-500 transition">Shows</a>
                        <a href="/student/my-tickets" class="hover:text-red-500 transition">My Passes</a>
                    <% } else if (user.role === 'volunteer') { %>
                        <a href="/volunteer/dashboard" class="hover:text-red-500 transition">Scanner</a>
                    <% } %>
                    <a href="/logout" class="bg-red-600 px-4 py-2 rounded-lg hover:bg-red-700 transition">Logout</a>
                <% } else { %>
                    <a href="/login" class="hover:text-red-500 transition">Login</a>
                    <a href="/signup" class="border border-red-600 text-red-600 px-4 py-2 rounded-lg hover:bg-red-600 hover:text-white transition">Sign Up</a>
                <% } %>
            </div>
        </div>
    </nav>