<%- include('../partials/header') %>

<div class="max-w-7xl mx-auto p-8 min-h-screen">
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-4xl font-black italic uppercase tracking-tighter">Volunteer <span class="text-red-600">Gate Mode</span></h1>
            <p class="text-gray-400 font-bold text-xs uppercase mt-1">Logged in as: <%= user.name %></p>
        </div>
        <a href="/volunteer/scanner" class="bg-red-600 text-white px-8 py-4 rounded-2xl font-black uppercase tracking-widest shadow-xl shadow-red-200 hover:bg-black transition-all animate-pulse">
            Open QR Scanner
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border-l-8 border-green-500">
            <p class="text-gray-400 font-black uppercase text-[10px] tracking-widest mb-1">Gate Status</p>
            <h2 class="text-2xl font-black uppercase italic">System Online</h2>
        </div>
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border-l-8 border-black">
            <p class="text-gray-400 font-black uppercase text-[10px] tracking-widest mb-1">Session</p>
            <h2 class="text-2xl font-black uppercase italic">Scanning Active</h2>
        </div>
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border-l-8 border-red-600">
            <p class="text-gray-400 font-black uppercase text-[10px] tracking-widest mb-1">Verification</p>
            <h2 class="text-2xl font-black uppercase italic text-red-600">Secure Entry</h2>
        </div>
    </div>

    <div class="bg-white rounded-[3rem] shadow-2xl p-10 border border-gray-100">
        <div class="flex justify-between items-center mb-8">
            <h3 class="text-2xl font-black uppercase italic tracking-tighter">Recent <span class="text-red-600">Scan Activity</span></h3>
            <span class="bg-gray-100 px-4 py-1 rounded-full text-[10px] font-black uppercase text-gray-400">Live Feed</span>
        </div>

        <div id="live-feed" class="space-y-4">
            <p id="no-data" class="text-center py-10 text-gray-300 font-bold uppercase italic">No recent scans in this session.</p>
        </div>
    </div>
</div>

<script>
    // Logic to pull the history we saved in the scanner page
    document.addEventListener('DOMContentLoaded', () => {
        const history = JSON.parse(localStorage.getItem('scanHistory') || '[]');
        const feed = document.getElementById('live-feed');
        const noData = document.getElementById('no-data');

        if (history.length > 0) {
            noData.remove();
            history.forEach(item => {
                const entry = `
                    <div class="flex justify-between items-center p-5 bg-gray-50 rounded-2xl border-l-4 ${item.success ? 'border-green-500' : 'border-red-500'}">
                        <div>
                            <p class="text-[10px] font-black uppercase text-gray-400">${item.name}</p>
                            <p class="text-xl font-black italic tracking-tighter">${item.seat}</p>
                        </div>
                        <div class="text-right">
                            <span class="text-[10px] font-bold text-gray-300">${item.time}</span>
                            <p class="text-[10px] font-black uppercase ${item.success ? 'text-green-600' : 'text-red-600'}">${item.success ? 'Verified' : 'Failed'}</p>
                        </div>
                    </div>
                `;
                feed.insertAdjacentHTML('beforeend', entry);
            });
        }
    });
</script>

<%- include('../partials/footer') %>